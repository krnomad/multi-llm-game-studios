    },
    {
      "id": "technical-director",
      "title": "Technical Director",
      "model_profile": "strategic_high",
      "delegation_intent": "single_delegate",
      "tool_capability_needs": [
        "file_read",
        "file_write",
        "file_edit",
        "pattern_search",
        "text_search",
        "web_fetch",
        "execute_shell"
      ],
      "source_manifest": "common/manifests/agents/technical-director.yaml"
    },
    {
      "id": "producer",
      "title": "Producer",
      "model_profile": "strategic_high",
      "delegation_intent": "multi_delegate",
      "tool_capability_needs": [
        "file_read",
        "file_write",
