      },
      {
        "stage_id": "decision",
        "objective": "Wait for the user to choose a direction and keep decision ownership with the human.",
        "actor": "user",
        "approval_gate": "none",
        "fallback_strategy": "generated_wrapper"
      },
      {
        "stage_id": "draft",
        "objective": "Show the proposed content or faithful summary of the full changeset before any write occurs.",
        "actor": "agent",
        "approval_gate": "none",
        "fallback_strategy": "protocol_downgrade"
      },
      {
        "stage_id": "approval",
        "objective": "Capture explicit approval for the pending writes before create or edit actions are executed.",
        "actor": "user",
        "approval_gate": "before_write",
        "fallback_strategy": "external_runner"
      }
    ],
    "invariants": {
      "approval_before_write": true,
      "human_decision_owner": true
