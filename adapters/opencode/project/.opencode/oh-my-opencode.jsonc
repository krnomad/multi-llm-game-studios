          "workflow",
          "runtime"
        ]
      },
      "rules": [
        {
          "code": "POL_TEST_NAMES_ARE_DESCRIPTIVE",
          "statement": "Tests should use descriptive names that encode the system, scenario, and expected result so failures remain readable and reviewable.",
